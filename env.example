# BlockVeil Support Bot - Environment Variables
# Copy this to .env for local development
# On Railway: set these in the Variables tab

# Your BotFather token
BOT_TOKEN=your_bot_token_here

# Telegram Group ID for "Need Support" tickets (negative number for groups, e.g. -100123456789)
SUPPORT_GROUP_ID=-100123456789

# Telegram Group ID for "Bug Report" and "Feature Request" tickets
BUG_FEATURE_GROUP_ID=-100987654321
